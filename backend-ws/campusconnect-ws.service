[Unit]
Description=CampusConnect WebSocket Server
After=network.target redis-server.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/campusconnect-ws
Environment="PATH=/opt/campusconnect-ws/venv/bin"
EnvironmentFile=/opt/campusconnect-ws/.env
ExecStart=/opt/campusconnect-ws/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
