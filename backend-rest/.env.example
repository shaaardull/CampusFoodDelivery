# Dev mode: skips JWT auth, auto-creates a dev user. Set to false in production.
DEV_MODE=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...your-secret-key

# JWT
JWT_SECRET=generate-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Resend (email OTP) - https://resend.com/api-keys
RESEND_API_KEY=re_...your-key

# OpenWeatherMap (optional, for surge pricing) - https://openweathermap.org/api
OWM_API_KEY=

# VAPID keys for push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@campusconnect.dev

# OTP
OTP_TTL_SECONDS=300
